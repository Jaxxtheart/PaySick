{
  "version": 2,
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "env": {
    "NODE_ENV": "production",
    "APP_URL": "https://paysick.co.za",
    "ALLOW_DEMO_LOGIN": "true",
    "CORS_ORIGIN": "https://paysick.co.za,https://www.paysick.co.za",
    "ALLOW_VERCEL_PREVIEWS": "true"
  }
}
