# ============================================
# PAYSICK ENVIRONMENT CONFIGURATION
# Banking-Grade Security Settings
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=development

# IMPORTANT: Set to 'production' in production environments
# NODE_ENV=production

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Local PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=paysick_db
DB_USER=paysick_user
DB_PASSWORD=your_secure_password_here

# Vercel Postgres (Use for Vercel deployment)
# POSTGRES_URL=postgresql://neondb_owner:npg_T4R3IBjbXury@ep-summer-recipe-ah32v90p-pooler.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require
# Automatically set by Vercel when you add Vercel Postgres

# ============================================
# SECURITY CONFIGURATION (REQUIRED IN PRODUCTION)
# ============================================

# Token Secret for Opaque Token Generation
# MUST be set in production - generate with: openssl rand -hex 64
# Application will FAIL TO START in production without this
TOKEN_SECRET=

# AES-256 Encryption Key for Sensitive Data (Banking Details)
# MUST be 32 bytes (64 hex characters) - generate with: openssl rand -hex 32
# Application will FAIL TO START in production without this
ENCRYPTION_KEY=

# ============================================
# CORS CONFIGURATION (REQUIRED IN PRODUCTION)
# ============================================

# Comma-separated list of allowed origins
# MUST be set in production - no wildcards allowed
CORS_ORIGIN=http://localhost:3000,http://localhost:5000

# ============================================
# RATE LIMITING
# ============================================

# Window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window per IP (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# DEVELOPMENT ONLY - REMOVE IN PRODUCTION
# ============================================

# These are development defaults - NEVER use in production
# The application uses secure random values if these are not set in development

# ============================================
# GENERATING SECURE KEYS
# ============================================
#
# Generate TOKEN_SECRET:
#   openssl rand -hex 64
#
# Generate ENCRYPTION_KEY:
#   openssl rand -hex 32
#
# Example (DO NOT USE THESE VALUES):
#   TOKEN_SECRET=a1b2c3d4e5f6...
#   ENCRYPTION_KEY=1234567890abcdef...
#
# ============================================
